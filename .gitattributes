* text=auto eol=lf

*.exe binary
*.dll binary
*.dat binary
*.zip binary

*.sh   text eol=lf
*.py   text eol=lf
*.conf text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.ps1  text eol=crlf

# git-crypt: encrypted at rest in repo, plaintext in working tree.
# Unlock with `git-crypt unlock` (uses GPG key listed in .git-crypt/keys/).
secrets.json filter=git-crypt diff=git-crypt
proxies.conf filter=git-crypt diff=git-crypt
